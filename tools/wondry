#!/usr/bin/env bash
# Wondry management CLI. install.sh symlinks this to /usr/local/bin/wondry, so on
# the Pi you can just run `wondry update`, `wondry logs`, etc. It finds its own
# install directory by resolving the symlink, so it works wherever it was cloned.
set -euo pipefail

DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
SERVICE=wondry
cd "$DIR"

rebuild() {
  npm install --no-fund --no-audit
  npm run build
  sudo systemctl restart "$SERVICE"
}

case "${1:-help}" in
  update)
    echo "Updating Wondry in $DIR…"
    before="$(git rev-parse HEAD)"
    # --autostash keeps any local edits (e.g. config.json) across the pull.
    git pull --rebase --autostash
    after="$(git rev-parse HEAD)"
    if [ "$before" = "$after" ]; then
      echo "Already up to date ($(git rev-parse --short HEAD)). Run 'wondry rebuild' to force a rebuild."
      exit 0
    fi
    echo "Updated to $(git rev-parse --short HEAD) — rebuilding and restarting…"
    rebuild
    echo "Done. Now running: $(git log -1 --format='%h %s')"
    ;;
  rebuild) rebuild; echo "Rebuilt and restarted.";;
  restart) sudo systemctl restart "$SERVICE"; echo "Restarted.";;
  start)   sudo systemctl start "$SERVICE";   echo "Started.";;
  stop)    sudo systemctl stop "$SERVICE";    echo "Stopped.";;
  status)  systemctl status "$SERVICE" --no-pager || true;;
  logs)    journalctl -u "$SERVICE" -f;;
  audio)   bash "$DIR/tools/devices.sh" select;;
  kokoro)
    # Turnkey Kokoro (optional natural neural voice): ensure the engine+model exist,
    # install the sidecar service, health-check it, then restart the app so it exposes
    # the Kokoro voices. Idempotent — safe to re-run.
    UNIT="$DIR/kokoro/wondry-kokoro.service"
    if [ ! -f "$UNIT" ] || [ ! -d "$DIR/.venv-kokoro" ]; then
      echo "Setting up the Kokoro engine + model (one-time; downloads ~170MB)…"
      npm run setup-kokoro
    fi
    [ -f "$UNIT" ] || { echo "Kokoro setup didn't produce $UNIT — re-run 'npm run setup-kokoro' and check its output." >&2; exit 1; }
    echo "Installing the Kokoro sidecar service…"
    sudo cp "$UNIT" /etc/systemd/system/wondry-kokoro.service
    sudo systemctl daemon-reload
    sudo systemctl enable --now wondry-kokoro
    # Health-check the sidecar (derive its URL from .env; it loads the model + warms the graph on boot).
    kurl="$(grep -E '^KOKORO_URL=' .env 2>/dev/null | cut -d= -f2- || true)"
    health="${kurl%/v1/audio/speech}/health"; health="${health:-http://127.0.0.1:8880/health}"
    printf "Waiting for the sidecar to warm up"
    ok=; for _ in $(seq 1 40); do
      if curl -fsS "$health" >/dev/null 2>&1; then ok=1; break; fi
      printf "."; sleep 1
    done; echo
    if [ "$ok" = 1 ]; then echo "✓ Kokoro sidecar is up ($health)."
    else echo "! Sidecar didn't answer $health yet — check: sudo systemctl status wondry-kokoro --no-pager" >&2; fi
    sudo systemctl restart "$SERVICE"
    echo "Restarted Wondry. Next: parent console → Kids → pick a kid → Voice → Kokoro → choose one → ▶ Hear voice."
    ;;
  version) git -C "$DIR" log -1 --format='%h %s (%cr)';;
  url)
    ip="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
    port="$(grep -E '^PORT=' .env 2>/dev/null | cut -d= -f2 || true)"; port="${port:-8080}"
    echo "Kiosk:   http://localhost:${port}/"
    echo "Console: http://${ip:-<pi-ip>}:${port}/admin/"
    ;;
  *)
    echo "Wondry — usage: wondry <command>"
    echo "  update    pull the latest, rebuild, and restart (keeps local config edits)"
    echo "  rebuild   reinstall deps + rebuild + restart (no pull)"
    echo "  restart   restart the server service"
    echo "  start | stop"
    echo "  status    service status"
    echo "  logs      follow the server logs"
    echo "  audio     pick the microphone / speaker / camera + set volume levels"
    echo "  kokoro    install the optional natural-voice (Kokoro) sidecar + enable it"
    echo "  version   the installed git revision"
    echo "  url       the kiosk + parent-console URLs"
    ;;
esac
